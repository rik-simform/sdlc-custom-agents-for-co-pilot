{
  "$schema": "https://raw.githubusercontent.com/sdlc-automation/schema/v1/sdlc-config.schema.json",
  "project": {
    "name": "MyProject",
    "type": "ASP.NET Core + Razor Pages",
    "targetFramework": "net8.0",
    "architectureStyle": "Clean Architecture with CQRS",
    "defaultBranch": "main"
  },
  "testing": {
    "framework": "MSTest",
    "coverageThreshold": 80,
    "e2eFramework": null
  },
  "cloud": {
    "provider": "Azure",
    "services": ["App Service", "Key Vault"]
  },
  "security": {
    "sast": "CodeQL",
    "dependencyScanning": "Dependabot",
    "owaspCompliance": "Top 10"
  },
  "documentation": {
    "adrPath": "docs/architecture/decisions",
    "requirementsPath": "docs/requirements",
    "runbookPath": "docs/operations"
  },
  "ci": {
    "dotnetVersion": "8.0.x",
    "configuration": "Release",
    "coverageThreshold": 80,
    "codeqlEnabled": true,
    "dependencyReviewEnabled": true,
    "integrationTestsEnabled": false
  },
  "cd": {
    "environments": ["staging", "production"],
    "deployTarget": "Azure App Service",
    "smokeTestEnabled": true,
    "rollbackEnabled": true
  },
  "agents": {
    "enabled": ["sdlc-orchestrator", "sdlc-requirements", "sdlc-architect", "sdlc-implementer", "sdlc-reviewer", "sdlc-tester", "sdlc-devops", "sdlc-security"],
    "disabled": []
  },
  "quality": {
    "conventionalCommits": true,
    "minReviewers": 1,
    "branchNamingPattern": "feature/{story-id}-{desc}"
  }
}
