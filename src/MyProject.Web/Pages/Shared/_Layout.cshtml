<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyProject.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyProject.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/Inventory/Index">
                    <i class="bi bi-boxes me-1"></i>Inventory
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var tokenSvc = Context.RequestServices.GetService<MyProject.Web.Services.TokenService>();
                            bool isAuth  = tokenSvc?.IsAuthenticated() ?? false;
                        }
                        @if (isAuth)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Inventory/Index">
                                    <i class="bi bi-table me-1"></i>All Items
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Inventory/Index" asp-route-filter="lowstock">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Low Stock
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Orders/MyOrders">
                                    <i class="bi bi-receipt me-1"></i>My Orders
                                </a>
                            </li>
                            @if (tokenSvc?.HasRole("Admin") ?? false)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-page="/Inventory/Create">
                                        <i class="bi bi-plus-circle me-1"></i>Add Item
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-page="/Orders/AllOrders">
                                        <i class="bi bi-boxes me-1"></i>All Orders
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (isAuth)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white-50">
                                    <i class="bi bi-person-circle me-1"></i>@(tokenSvc!.GetUserEmail())
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-page="/Account/Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus me-1"></i>Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Error"] is string tempError)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @tempError
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; @DateTime.UtcNow.Year — Inventory Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>