@page "{id:guid}"
@model MyProject.Web.Pages.Inventory.EditModel
@{
    ViewData["Title"] = "Edit Inventory Item";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">
                    <i class="bi bi-pencil me-2"></i>Edit — <code>@Model.Input.Sku</code>
                </h4>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Input.Sku" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Input.Name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input asp-for="Input.Name" class="form-control" />
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Input.Description" class="form-label">Description</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Input.Category" class="form-label">Category <span class="text-danger">*</span></label>
                            <input asp-for="Input.Category" class="form-control" />
                            <span asp-validation-for="Input.Category" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Input.QuantityInStock" class="form-label">Quantity <span class="text-danger">*</span></label>
                            <input asp-for="Input.QuantityInStock" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Input.QuantityInStock" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Input.ReorderLevel" class="form-label">Reorder Level <span class="text-danger">*</span></label>
                            <input asp-for="Input.ReorderLevel" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Input.ReorderLevel" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Input.UnitPrice" class="form-label">Unit Price <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Input.UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="Input.UnitPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Input.Location" class="form-label">Location</label>
                            <input asp-for="Input.Location" class="form-control" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning text-dark">
                            <i class="bi bi-save me-1"></i>Update Item
                        </button>
                        <a asp-page="/Inventory/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
