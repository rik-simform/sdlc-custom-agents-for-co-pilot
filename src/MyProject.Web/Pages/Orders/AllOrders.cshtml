@page
@model MyProject.Web.Pages.Orders.AllOrdersModel
@{
    ViewData["Title"] = "All Orders (Admin)";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>
                <i class="bi bi-boxes me-2"></i>All Orders <span class="badge bg-danger">Admin Only</span>
            </h2>
            <p class="text-muted">Manage all placed orders in the system</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Error:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            <strong>Success:</strong> @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] is string tempError)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Error:</strong> @tempError
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <input type="text" name="userFilter" value="@Model.UserFilter" class="form-control" placeholder="Search user/email" />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">All statuses</option>
                @foreach (var s in new[] { "Pending", "Cancelled", "Fulfilled" })
                {
                    if (string.Equals(Model.Status, s, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <input type="number" min="1" max="100" name="pageSize" value="@Model.PageSize" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
        </div>
    </form>

    @if (Model.Orders.Count == 0)
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox me-2"></i>
            <p>No orders have been placed yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Order Date</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Item Name</th>
                        <th>Qty</th>
                        <th>Status</th>
                        <th>Fulfilled</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td>
                                <small class="text-muted">
                                    @order.OrderedAt.LocalDateTime.ToString("g")
                                </small>
                            </td>
                            <td>
                                <strong>@order.UserName</strong>
                            </td>
                            <td>
                                <small>@order.UserEmail</small>
                            </td>
                            <td>
                                <strong>@order.ItemName</strong>
                            </td>
                            <td>
                                <span class="badge bg-info">@order.QuantityRequested</span>
                            </td>
                            <td>
                                @{
                                    var statusBadge = order.Status switch
                                    {
                                        "Pending" => "warning",
                                        "Processing" => "info",
                                        "Shipped" => "primary",
                                        "Delivered" => "success",
                                        "Fulfilled" => "success",
                                        "Cancelled" => "danger",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@statusBadge">@order.Status</span>
                            </td>
                            <td>
                                @if (order.FulfilledAt.HasValue)
                                {
                                    <small class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>@order.FulfilledAt.Value.LocalDateTime.ToString("g")
                                    </small>
                                }
                                else
                                {
                                    <small class="text-muted">
                                        <i class="bi bi-clock me-1"></i>Pending
                                    </small>
                                }
                            </td>
                            <td>
                                @if (order.Status == "Pending")
                                {
                                    <form method="post" asp-page-handler="Fulfill" class="d-inline">
                                        <input type="hidden" name="orderId" value="@order.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-success"
                                                onclick="return confirm('Mark this order as fulfilled?')">
                                            <i class="bi bi-check-lg me-1"></i>Fulfill
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <small class="text-muted">—</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.OrdersPage is not null && Model.OrdersPage.TotalPages > 1)
        {
            <nav class="mt-3" aria-label="Orders pagination">
                <ul class="pagination">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./AllOrders" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-pageSize="@Model.PageSize" asp-route-status="@Model.Status" asp-route-userFilter="@Model.UserFilter">Previous</a>
                    </li>
                    <li class="page-item active">
                        <span class="page-link">Page @Model.CurrentPage of @Model.OrdersPage.TotalPages</span>
                    </li>
                    <li class="page-item @(Model.CurrentPage >= Model.OrdersPage.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./AllOrders" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-pageSize="@Model.PageSize" asp-route-status="@Model.Status" asp-route-userFilter="@Model.UserFilter">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<style>
    .table {
        margin-bottom: 0;
        font-size: 0.9rem;
    }

    .table thead th {
        border-bottom: 2px solid #dee2e6;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    code {
        background-color: #f5f5f5;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.875rem;
    }

    .sticky-top {
        top: 0;
        z-index: 10;
    }
</style>
