@page
@model MyProject.Web.Pages.Orders.AllOrdersModel
@{
    ViewData["Title"] = "All Orders (Admin)";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>
                <i class="bi bi-boxes me-2"></i>All Orders <span class="badge bg-danger">Admin Only</span>
            </h2>
            <p class="text-muted">Manage all placed orders in the system</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Error:</strong> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            <strong>Success:</strong> @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] is string tempError)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Error:</strong> @tempError
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Orders.Count == 0)
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox me-2"></i>
            <p>No orders have been placed yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-sm">
                <thead class="table-dark sticky-top">
                    <tr>
                        <th>Order Date</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Item Name</th>
                        <th>SKU</th>
                        <th>Unit Price</th>
                        <th>Qty</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Fulfilled</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        var itemTotal = order.UnitPrice * order.QuantityRequested;
                        <tr>
                            <td>
                                <small class="text-muted">
                                    @order.OrderedAt.LocalDateTime.ToString("g")
                                </small>
                            </td>
                            <td>
                                <strong>@order.UserName</strong>
                            </td>
                            <td>
                                <small>@order.UserEmail</small>
                            </td>
                            <td>
                                <strong>@order.ItemName</strong>
                            </td>
                            <td>
                                <code>@order.ItemSku</code>
                            </td>
                            <td>
                                <span class="text-end">$@order.UnitPrice.ToString("F2")</span>
                            </td>
                            <td>
                                <span class="badge bg-info">@order.QuantityRequested</span>
                            </td>
                            <td>
                                <strong class="text-success">$@itemTotal.ToString("F2")</strong>
                            </td>
                            <td>
                                @{
                                    var statusBadge = order.Status switch
                                    {
                                        "Pending" => "warning",
                                        "Processing" => "info",
                                        "Shipped" => "primary",
                                        "Delivered" => "success",
                                        "Cancelled" => "danger",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@statusBadge">@order.Status</span>
                            </td>
                            <td>
                                @if (order.FulfilledAt.HasValue)
                                {
                                    <small class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>@order.FulfilledAt.Value.LocalDateTime.ToString("g")
                                    </small>
                                }
                                else
                                {
                                    <small class="text-muted">
                                        <i class="bi bi-clock me-1"></i>Pending
                                    </small>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(order.Notes))
                                {
                                    <small class="text-muted" title="@order.Notes">
                                        @(order.Notes.Length > 25 ? order.Notes.Substring(0, 25) + "..." : order.Notes)
                                    </small>
                                }
                                else
                                {
                                    <small class="text-muted">-</small>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#updateStatusModal@(order.Id.ToString("N"))">
                                    <i class="bi bi-pencil me-1"></i>Update
                                </button>
                            </td>
                        </tr>

                        <!-- Update Status Modal -->
                        <div class="modal fade" id="updateStatusModal@(order.Id.ToString("N"))" tabindex="-1" aria-labelledby="updateStatusLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Update Order Status</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <form method="post" asp-page-handler="UpdateOrderStatus">
                                        <input type="hidden" name="orderId" value="@order.Id" />
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label for="itemName" class="form-label">Item</label>
                                                <input type="text" class="form-control" id="itemName" value="@order.ItemName" disabled />
                                            </div>
                                            <div class="mb-3">
                                                <label for="customerName" class="form-label">Customer</label>
                                                <input type="text" class="form-control" id="customerName" value="@order.UserName" disabled />
                                            </div>
                                            <div class="mb-3">
                                                <label for="status@(order.Id.ToString("N"))" class="form-label">Status</label>
                                                <select class="form-select" id="status@(order.Id.ToString("N"))" name="newStatus" required>
                                                    <option value="">-- Select Status --</option>
                                                    @{
                                                        var statuses = new[] { "Pending", "Processing", "Shipped", "Delivered", "Cancelled" };
                                                        foreach (var status in statuses)
                                                        {
                                                            if (order.Status == status)
                                                            {
                                                                <option value="@status" selected>@status</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@status">@status</option>
                                                            }
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label for="notes@(order.Id.ToString("N"))" class="form-label">Notes (Optional)</label>
                                                <textarea class="form-control" id="notes@(order.Id.ToString("N"))" name="notes" rows="2" maxlength="500" placeholder="Add any notes...">@(order.Notes ?? "")</textarea>
                                                <small class="form-text text-muted">Max 500 characters</small>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-check-lg me-1"></i>Save Changes
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 text-muted">
            <small>Total Orders: <strong>@Model.Orders.Count</strong></small>
        </div>
    }
</div>

<style>
    .table {
        margin-bottom: 0;
        font-size: 0.9rem;
    }

    .table thead th {
        border-bottom: 2px solid #dee2e6;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    code {
        background-color: #f5f5f5;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.875rem;
    }

    .sticky-top {
        top: 0;
        z-index: 10;
    }
</style>
